---
import BaseLayout from '../layouts/BaseLayout.astro';
import { NAV_LINKS } from '../consts';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="404" description="页面走丢了">
  <section class="mx-auto flex max-w-2xl flex-col items-center px-4 py-24 text-center">
    <div class="animate-fade-up">
      <p class="font-mono text-[8rem] font-extrabold leading-none md:text-[12rem]">
        <span>404</span>
      </p>
      <h1 class="mt-2 text-2xl font-bold md:text-3xl">这页没有收进档案</h1>
      <p class="mt-4 text-muted">它可能已被移动，或者从未存在过。</p>
    </div>

    <div class="mt-10 flex flex-wrap justify-center gap-3">
      <a href={base} class="btn-gradient px-6 py-3 font-semibold">
        回到首页
      </a>
      <a href={`${base}posts`} class="glass px-6 py-3 font-semibold transition-transform hover:-translate-y-0.5">
        浏览文章
      </a>
    </div>

    <nav class="mt-10 flex flex-wrap justify-center gap-4 text-sm text-muted">
      {NAV_LINKS.map((link) => (
        <a href={`${base}${link.href.replace(/^\//, '')}`} class="link-hover hover:text-accent">
          {link.text}
        </a>
      ))}
    </nav>
  </section>
</BaseLayout>
