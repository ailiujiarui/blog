---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getPublishedPosts, groupByYear } from '../../lib/posts';

const posts = await getPublishedPosts();
const byYear = groupByYear(posts);
const total = posts.length;
---

<BaseLayout title="文章" description={`全部文章 · 共 ${total} 篇`}>
  <section class="mx-auto max-w-5xl px-4">
    <header class="mb-10 animate-fade-up">
      <h1 class="text-4xl font-extrabold tracking-tight md:text-5xl">
        <span class="text-gradient">全部文章</span>
      </h1>
      <p class="mt-3 text-muted">共 {total} 篇文章 · 按时间倒序</p>
    </header>

    {posts.length === 0 ? (
      <div class="glass rounded-2xl p-10 text-center text-muted">
        还没有文章，去 <code>src/content/posts/</code> 写一篇吧。
      </div>
    ) : (
      <div class="space-y-12">
        {[...byYear.entries()].map(([year, items]) => (
          <section>
            <div class="mb-5 flex items-center gap-4">
              <h2 class="text-2xl font-bold text-fg">{year}</h2>
              <div class="h-px flex-1 bg-gradient-to-r from-accent/40 to-transparent"></div>
              <span class="text-sm text-muted">{items.length} 篇</span>
            </div>
            <div class="grid gap-6 md:grid-cols-2">
              {items.map((post) => (
                <PostCard
                  title={post.data.title}
                  description={post.data.description}
                  pubDate={post.data.pubDate}
                  tags={post.data.tags}
                  url={post.slug}
                />
              ))}
            </div>
          </section>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
