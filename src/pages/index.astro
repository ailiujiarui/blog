---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import Search from '../components/Search.astro';
import { getPublishedPosts } from '../lib/posts';
import { SITE } from '../consts';

const posts = await getPublishedPosts();
const recent = posts.slice(0, SITE.pageSize);
const featured = recent[0];
const rest = recent.slice(1);
const base = import.meta.env.BASE_URL;
const toDateKey = (date: Date) => date.toISOString().slice(0, 10);
const postCountsByDate = new Map<string, number>();

for (const post of posts) {
  const key = toDateKey(post.data.pubDate);
  postCountsByDate.set(key, (postCountsByDate.get(key) ?? 0) + 1);
}

const latestPostDate = posts.length
  ? new Date(Math.max(...posts.map((post) => post.data.pubDate.getTime())))
  : new Date();
latestPostDate.setHours(0, 0, 0, 0);

const heatmapWeeks = 36;
const heatmapStart = new Date(latestPostDate);
heatmapStart.setDate(latestPostDate.getDate() - heatmapWeeks * 7 + 1);

const heatmapDays = Array.from({ length: heatmapWeeks * 7 }, (_, index) => {
  const date = new Date(heatmapStart);
  date.setDate(heatmapStart.getDate() + index);
  const key = toDateKey(date);
  const count = postCountsByDate.get(key) ?? 0;
  return {
    key,
    count,
    level: Math.min(count, 4),
    label: `${key}: ${count} 篇文章`,
  };
});

const activeDays = [...postCountsByDate.values()].filter((count) => count > 0).length;
const tagCounts = new Map<string, number>();

for (const post of posts) {
  for (const tag of post.data.tags) {
    tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
  }
}

const topTags = [...tagCounts.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 4);

const latestActivity = posts.slice(0, 3);
---

<BaseLayout>
  <section class="paper-stage mx-auto max-w-6xl">
    <div class="paper-hero">
      <div class="paper-hero-copy">
        <div class="paper-kicker">FIELD NOTES / CODE / LIFE</div>

        <h1 class="paper-title">
          我思考
          <span>我存在</span>
        </h1>

        <p class="paper-lead">
          追随jojo大王学习的脚步
        </p>

        <div class="paper-actions">
          <a href={`${base}posts`} class="paper-button paper-button--primary">浏览文章</a>
          <a href={`${base}about`} class="paper-button">关于我</a>
        </div>
      </div>

      <aside class="build-note">
        <strong>build note</strong>
        <code>
          const taste = paper<br />
          &nbsp;&nbsp;+ motion<br />
          &nbsp;&nbsp;+ typesetting;<br />
          export default human;
        </code>
      </aside>
    </div>

    <div class="aplus-marquee" aria-hidden="true">
      <div>
        Build fast, learn faster / Build fast, learn faster / Build fast, learn faster / Build fast, learn faster /
      </div>
    </div>

    <div class="paper-grid">
      <aside class="aplus-side">
        <div class="side-block">
          <b>INDEX</b>
          <a href={`${base}posts`}>01 最新文章</a>
          <a href={`${base}tags/开源之夏`}>02 开源之夏</a>
          <a href={`${base}tags/随笔`}>03 随笔</a>
          <a href={`${base}about`}>04 关于作者</a>
        </div>
        <div class="side-block">
          <b>SEARCH</b>
          <p>索引跟着文章走，查找时像脚注批注一样展开。</p>
        </div>
        <Search />
      </aside>

      <div class="paper-feed">
        <div class="feed-heading">
          <div>
            <p class="feed-eyebrow">latest dispatches</p>
            <h2>最新文章</h2>
          </div>
          <a href={`${base}posts`}>查看全部</a>
        </div>

        {recent.length > 0 && (
          <div class="paper-posts">
            {featured && (
            <PostCard
              title={featured.data.title}
              description={featured.data.description}
              pubDate={featured.data.pubDate}
              tags={featured.data.tags}
              url={featured.slug}
              featured
            />
            )}

            {rest.map((post) => (
              <PostCard
                title={post.data.title}
                description={post.data.description}
                pubDate={post.data.pubDate}
                tags={post.data.tags}
                url={post.slug}
              />
            ))}
          </div>
        )}
      </div>
    </div>

    <section id="writing-heatmap" class="heatmap-section">
      <div class="heatmap-heading">
        <div>
          <p class="feed-eyebrow">writing heatmap</p>
          <h2>写作热力图</h2>
        </div>
        <div class="heatmap-stats">
          <span>{posts.length} notes</span>
          <span>{activeDays} active days</span>
        </div>
      </div>

      <div class="heatmap-layout">
        <div>
          <div class="heatmap-scroll" role="img" aria-label={`最近 ${heatmapWeeks} 周写作热力图`}>
            <div class="heatmap-grid">
              {heatmapDays.map((day) => (
                <span
                  class:list={['heat-cell', `heat-cell--${day.level}`]}
                  title={day.label}
                  aria-label={day.label}
                />
              ))}
            </div>
          </div>

          <div class="heatmap-legend" aria-hidden="true">
            <span>less</span>
            <i class="heat-cell heat-cell--0"></i>
            <i class="heat-cell heat-cell--1"></i>
            <i class="heat-cell heat-cell--2"></i>
            <i class="heat-cell heat-cell--3"></i>
            <i class="heat-cell heat-cell--4"></i>
            <span>more</span>
          </div>
        </div>

        <aside class="heatmap-panel">
          <b>RECENT</b>
          {latestActivity.map((post) => (
            <a href={`${base}posts/${post.slug}`}>
              <span>{toDateKey(post.data.pubDate)}</span>
              {post.data.title}
            </a>
          ))}

          <b>TOP TAGS</b>
          <div class="heatmap-tags">
            {topTags.map(([tag, count]) => (
              <span>#{tag} {count}</span>
            ))}
          </div>
        </aside>
      </div>
    </section>
  </section>
</BaseLayout>
