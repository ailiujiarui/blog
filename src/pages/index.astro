---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import Search from '../components/Search.astro';
import { getPublishedPosts } from '../lib/posts';
import { SITE } from '../consts';

const posts = await getPublishedPosts();
const recent = posts.slice(0, SITE.pageSize);
const featured = recent[0];
const rest = recent.slice(1);
const base = import.meta.env.BASE_URL;
---

<BaseLayout>
  <section class="paper-stage mx-auto max-w-6xl">
    <div class="paper-hero">
      <div class="paper-hero-copy">
        <div class="paper-kicker">FIELD NOTES / CODE / LIFE</div>

        <h1 class="paper-title">
          我思考
          <span>我存在</span>
        </h1>

        <p class="paper-lead">
          追随jojo大王学习的脚步
        </p>

        <div class="paper-actions">
          <a href={`${base}posts`} class="paper-button paper-button--primary">浏览文章</a>
          <a href={`${base}about`} class="paper-button">关于我</a>
        </div>
      </div>

      <aside class="build-note">
        <strong>build note</strong>
        <code>
          const taste = paper<br />
          &nbsp;&nbsp;+ motion<br />
          &nbsp;&nbsp;+ typesetting;<br />
          export default human;
        </code>
      </aside>
    </div>

    <div class="aplus-marquee" aria-hidden="true">
      <div>
        Build fast, learn faster / Build fast, learn faster / Build fast, learn faster / Build fast, learn faster /
      </div>
    </div>

    <div class="paper-grid">
      <aside class="aplus-side">
        <div class="side-block">
          <b>INDEX</b>
          <a href={`${base}posts`}>01 最新文章</a>
          <a href={`${base}tags/Astro`}>02 技术笔记</a>
          <a href={`${base}tags/CSS`}>03 设计实验</a>
          <a href={`${base}about`}>04 关于作者</a>
        </div>
        <div class="side-block">
          <b>SEARCH</b>
          <p>结果像脚注批注一样展开，不抢正文风头。</p>
        </div>
        <Search />
      </aside>

      <div class="paper-feed">
        <div class="feed-heading">
          <div>
            <p class="feed-eyebrow">latest dispatches</p>
            <h2>最新文章</h2>
          </div>
          <a href={`${base}posts`}>查看全部</a>
        </div>

        {recent.length > 0 && (
          <div class="paper-posts">
            {featured && (
            <PostCard
              title={featured.data.title}
              description={featured.data.description}
              pubDate={featured.data.pubDate}
              tags={featured.data.tags}
              url={featured.slug}
              featured
            />
            )}

            {rest.map((post) => (
              <PostCard
                title={post.data.title}
                description={post.data.description}
                pubDate={post.data.pubDate}
                tags={post.data.tags}
                url={post.slug}
              />
            ))}
          </div>
        )}
      </div>
    </div>
  </section>
</BaseLayout>
