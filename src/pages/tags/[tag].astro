---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import TagPill from '../../components/TagPill.astro';
import { getPublishedPosts } from '../../lib/posts';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const tags = new Map<string, number>();
  for (const post of posts) {
    for (const tag of post.data.tags) {
      tags.set(tag, (tags.get(tag) ?? 0) + 1);
    }
  }
  return [...tags.keys()].map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: posts.filter((p) => p.data.tags.includes(tag)),
    },
  }));
}

const { tag, posts } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<BaseLayout title={`#${tag}`} description={`标签 ${tag} 下的 ${posts.length} 篇文章`}>
  <section class="mx-auto max-w-5xl px-4">
    <a
      href={`${base}tags`}
      class="mb-8 inline-flex items-center gap-1.5 text-sm text-muted transition-colors hover:text-accent"
    >
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
      </svg>
      全部标签
    </a>

    <header class="mb-10 animate-fade-up">
      <div class="mb-4">
        <TagPill text={tag} />
      </div>
      <h1 class="text-4xl font-extrabold tracking-tight md:text-5xl">
        <span class="text-gradient">#{tag}</span>
      </h1>
      <p class="mt-3 text-muted">共 {posts.length} 篇文章</p>
    </header>

    <div class="grid gap-6 md:grid-cols-2">
      {posts.map((post) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          tags={post.data.tags}
          url={post.slug}
        />
      ))}
    </div>
  </section>
</BaseLayout>
