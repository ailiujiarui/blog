---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import TagPill from '../../components/TagPill.astro';
import { getAllTags, getPublishedPosts } from '../../lib/posts';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const tags = await getAllTags();

  return tags.map(({ tag }) => ({
    params: { tag },
    props: {
      tag,
      posts: posts.filter((post) => post.data.tags.includes(tag)),
    },
  }));
}

const { tag, posts } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<BaseLayout title={`#${tag}`} description={`标签 ${tag} 下的 ${posts.length} 篇文章`}>
  <section class="mx-auto max-w-5xl px-4">
    <a
      href={`${base}tags`}
      class="mb-8 inline-flex items-center gap-1.5 font-mono text-xs uppercase text-muted transition-colors hover:text-accent"
    >
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
      </svg>
      全部标签
    </a>

    <header class="mb-10 animate-fade-up border-b border-border/80 pb-8">
      <div class="mb-4">
        <TagPill text={tag} />
      </div>
      <h1 class="font-serif text-4xl font-semibold md:text-5xl">
        <span>#{tag}</span>
      </h1>
      <p class="mt-3 text-muted">共 {posts.length} 篇文章</p>
    </header>

    {posts.length === 0 ? (
      <div class="glass p-10 text-center text-muted">
        这个标签下还没有文章。
      </div>
    ) : (
      <div class="grid">
        {posts.map((post) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            tags={post.data.tags}
            url={post.slug}
          />
        ))}
      </div>
    )}
  </section>
</BaseLayout>
