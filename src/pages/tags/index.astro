---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TagPill from '../../components/TagPill.astro';
import { getAllTags } from '../../lib/posts';

const tags = await getAllTags();
const base = import.meta.env.BASE_URL;

// 根据计数映射字号，做标签云效果
const max = Math.max(1, ...tags.map((t) => t.count));
const scale = (count: number) => 0.85 + (count / max) * 0.9;
---

<BaseLayout title="标签" description={`按标签浏览 · 共 ${tags.length} 个标签`}>
  <section class="mx-auto max-w-4xl px-4">
    <header class="mb-10 animate-fade-up">
      <h1 class="text-4xl font-extrabold tracking-tight md:text-5xl">
        <span class="text-gradient">标签</span>
      </h1>
      <p class="mt-3 text-muted">共 {tags.length} 个标签 · 点击查看该标签下的全部文章</p>
    </header>

    {tags.length === 0 ? (
      <div class="glass rounded-2xl p-10 text-center text-muted">
        还没有标签。
      </div>
    ) : (
      <div class="glass animate-fade-in flex flex-wrap gap-3 rounded-2xl p-8">
        {tags.map(({ tag, count }) => (
          <a
            href={`${base}tags/${tag}`}
            class="tag-pill"
            style={`font-size: ${scale(count)}rem;`}
          >
            #{tag}
            <span class="ml-1.5 text-[0.7rem] opacity-70">({count})</span>
          </a>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
