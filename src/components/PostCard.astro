---
import FormattedDate from './FormattedDate.astro';
import TagPill from './TagPill.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags?: string[];
  url: string;
  featured?: boolean;
}
const { title, description, pubDate, tags = [], url, featured = false } = Astro.props;
const base = import.meta.env.BASE_URL;
const href = `${base}posts/${url.replace(/^\//, '')}`;
---

<article
  class:list={[
    'aplus-post group',
    featured && 'aplus-post--featured',
  ]}
>
  <div class="aplus-post-date">
    <FormattedDate date={pubDate} />
  </div>

  <div class="aplus-post-main">
    <div class="aplus-post-meta">
      <span class="uppercase tracking-[0.16em]">note</span>
      {tags.slice(0, 2).map((tag) => (
        <span class="text-accent">#{tag}</span>
      ))}
    </div>

    <h3 class:list={['aplus-post-title', featured && 'aplus-post-title--featured']}>
      <a href={href}>
        <span class="absolute inset-0" aria-hidden="true"></span>
        {title}
      </a>
    </h3>

    <p class="mt-3 line-clamp-2 text-sm leading-relaxed text-muted md:max-w-2xl">
      {description}
    </p>
  </div>

  {tags.length > 0 && (
    <div class="aplus-post-tags relative z-10">
      {tags.slice(0, featured ? 4 : 2).map((tag) => <TagPill text={tag} />)}
    </div>
  )}
</article>
