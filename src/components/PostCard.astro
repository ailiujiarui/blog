---
import FormattedDate from './FormattedDate.astro';
import TagPill from './TagPill.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags?: string[];
  url: string;
  featured?: boolean;
}
const { title, description, pubDate, tags = [], url, featured = false } = Astro.props;
const base = import.meta.env.BASE_URL;
const href = `${base}posts/${url.replace(/^\//, '')}`;
---

<article
  class:list={[
    'group glass relative overflow-hidden rounded-2xl p-6 transition-all duration-300',
    'hover:-translate-y-1.5 hover:shadow-2xl hover:shadow-accent/10',
    featured && 'md:p-8',
  ]}
>
  <!-- 装饰性渐变光晕 -->
  <div
    class="pointer-events-none absolute -right-16 -top-16 h-40 w-40 rounded-full opacity-0 blur-3xl transition-opacity duration-500 group-hover:opacity-30"
    style="background: radial-gradient(circle, rgb(var(--color-accent)), transparent 70%);"
  ></div>

  <div class="relative">
    <div class="mb-3 flex items-center gap-3 text-xs text-muted">
      <FormattedDate date={pubDate} />
      {tags.length > 0 && <span class="text-border">·</span>}
      {tags.slice(0, 2).map((tag) => (
        <span class="text-accent">#{tag}</span>
      ))}
    </div>

    <h3 class:list={["font-bold leading-snug tracking-tight", featured ? "text-2xl md:text-3xl" : "text-xl"]}>
      <a href={href} class="link-hover">
        <span class="absolute inset-0" aria-hidden="true"></span>
        {title}
      </a>
    </h3>

    <p class="mt-3 line-clamp-2 text-sm leading-relaxed text-muted">
      {description}
    </p>

    {tags.length > 0 && (
      <div class="relative z-10 mt-4 flex flex-wrap gap-2">
        {tags.map((tag) => <TagPill text={tag} />)}
      </div>
    )}
  </div>
</article>
