---
// 暗/亮主题切换按钮：读 localStorage，写 .dark 类
---
<button
  id="theme-toggle"
  type="button"
  aria-label="切换主题"
  title="切换明暗主题"
  class="relative grid h-9 w-9 place-items-center border border-border bg-bg/80 transition-transform hover:-rotate-2 hover:bg-fg hover:text-bg active:scale-95 sm:h-10 sm:w-10"
>
  <!-- 太阳（亮色时显示） -->
  <svg
    class="sun h-5 w-5"
    fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"
  >
    <circle cx="12" cy="12" r="4" />
    <path stroke-linecap="round" d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
  </svg>
  <!-- 月亮（暗色时显示） -->
  <svg
    class="moon hidden h-5 w-5"
    fill="currentColor" viewBox="0 0 24 24"
  >
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
  </svg>
</button>

<script>
  // 初始图标与当前主题对齐（防 FOUT）
  function syncIcon() {
    const isDark = document.documentElement.classList.contains('dark');
    document.querySelector('#theme-toggle .sun')?.classList.toggle('hidden', isDark);
    document.querySelector('#theme-toggle .moon')?.classList.toggle('hidden', !isDark);
  }
  syncIcon();

  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const root = document.documentElement;
    const isDark = root.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
    syncIcon();
  });

  // 跟随系统变化（仅当用户未手动设置时）
  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
    if (!localStorage.getItem('theme')) {
      document.documentElement.classList.toggle('dark', e.matches);
      syncIcon();
    }
  });
</script>
