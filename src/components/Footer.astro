---
import { SITE } from '../consts';
import '../styles/global.css';
const year = new Date().getFullYear();
const social = SITE.social;
const base = import.meta.env.BASE_URL;
const rssHref = `${base}rss.xml`;
---

<footer class="px-4 pb-10 pt-8">
  <div class="glass mx-auto max-w-6xl px-6 py-8">
    <div class="flex flex-col items-center gap-6 text-center md:flex-row md:justify-between md:text-left">
      <div>
        <p class="font-semibold">{SITE.title}</p>
        <p class="mt-1 text-sm text-muted">{SITE.description}</p>
      </div>

      <div class="flex items-center gap-3">
        {social.github && (
          <a href={social.github} target="_blank" rel="noopener" aria-label="GitHub"
             class="grid h-10 w-10 place-items-center border border-border bg-fg/5 transition-colors hover:bg-accent/15 hover:text-accent">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.3.8-.6v-2c-3.2.7-3.9-1.5-3.9-1.5-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.4-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2 1-.3 2-.4 3-.4s2 .1 3 .4c2.3-1.5 3.3-1.2 3.3-1.2.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5z"/></svg>
          </a>
        )}
        {social.twitter && (
          <a href={social.twitter} target="_blank" rel="noopener" aria-label="Twitter"
             class="grid h-10 w-10 place-items-center border border-border bg-fg/5 transition-colors hover:bg-accent/15 hover:text-accent">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
        )}
        {social.email && (
          <a href={social.email} aria-label="Email"
             class="grid h-10 w-10 place-items-center border border-border bg-fg/5 transition-colors hover:bg-accent/15 hover:text-accent">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 7l9 6 9-6M4 5h16a1 1 0 011 1v12a1 1 0 01-1 1H4a1 1 0 01-1-1V6a1 1 0 011-1z"/></svg>
          </a>
        )}
        <a href={rssHref} aria-label="RSS"
           class="grid h-10 w-10 place-items-center border border-border bg-fg/5 transition-colors hover:bg-accent/15 hover:text-accent">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor"><path d="M6.18 17.82a2.18 2.18 0 1 1-4.36 0 2.18 2.18 0 0 1 4.36 0zM2 8.18v3a8.82 8.82 0 0 1 8.82 8.82h3A11.82 11.82 0 0 0 2 8.18zM2 2v3a14.82 14.82 0 0 1 14.82 14.82h3A17.82 17.82 0 0 0 2 2z"/></svg>
        </a>
      </div>
    </div>

    <div class="mt-6 border-t border-border/60 pt-5 text-center text-xs text-muted">
      <p>© {year} {SITE.author}. 由 <a href="https://astro.build" target="_blank" rel="noopener" class="link-hover text-accent">Astro</a> 强力驱动 · Field Notes 主题</p>
    </div>
  </div>
</footer>
