---
import { SITE, NAV_LINKS } from '../consts';
import ThemeToggle from './ThemeToggle.astro';

const { pathname } = Astro.url;
// 处理部署到子路径的情况（base 路径）
const base = import.meta.env.BASE_URL;
const isActive = (href: string) => {
  const target = (base + href.replace(/^\//, '')).replace(/\/$/, '') || '/';
  const current = pathname.replace(/\/$/, '') || '/';
  return current === target || (href !== '/' && current.startsWith(target));
};
---

<header class="site-header sticky top-0 z-40 px-4 pt-4">
  <nav class="mx-auto flex w-full max-w-6xl items-center justify-between border-b border-border/80 bg-bg/85 px-0 pb-4 md:backdrop-blur-md">
    <!-- Logo -->
    <a href={base} class="group flex min-w-0 items-baseline gap-2 sm:gap-3">
      <span class="site-mark">GE</span>
      <span class="site-wordmark">{SITE.title}</span>
      <span class="hidden text-xs uppercase tracking-[0.22em] text-muted md:inline">field notes</span>
    </a>

    <!-- 导航链接 -->
    <div class="hidden items-center gap-6 md:flex">
      {NAV_LINKS.map((link) => (
        <a
          href={base + link.href.replace(/^\//, '')}
          class:list={[
            'nav-link text-xs uppercase tracking-[0.18em] transition-colors',
            isActive(link.href)
              ? 'text-fg'
              : 'text-muted hover:text-fg',
          ]}
        >
          {link.text}
        </a>
      ))}
      <span class="site-status">online</span>
    </div>

    <div class="site-controls flex shrink-0 items-center gap-1 sm:gap-2">
      <ThemeToggle />
      <!-- 移动端菜单 -->
      <button
        id="mobile-menu-btn"
        type="button"
        aria-label="菜单"
        class="grid h-8 w-8 place-items-center border border-border bg-bg/80 sm:h-10 sm:w-10 md:hidden"
      >
        <svg class="h-4 w-4 sm:h-5 sm:w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" d="M4 7h16M4 12h16M4 17h16" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- 移动端下拉 -->
  <div
    id="mobile-menu"
    class="mx-auto mt-2 hidden max-w-6xl border border-border bg-bg/95 p-2 shadow-paper md:hidden"
  >
    {NAV_LINKS.map((link) => (
      <a
        href={base + link.href.replace(/^\//, '')}
        class:list={[
          'block px-4 py-3 text-sm font-medium transition-colors',
          isActive(link.href)
            ? 'text-accent'
            : 'text-fg/80 hover:bg-fg/5',
        ]}
      >
        {link.text}
      </a>
    ))}
    <div class="site-status mx-4 my-3">online</div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
