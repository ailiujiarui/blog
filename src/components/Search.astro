---
// Pagefind 搜索组件：构建后 pagefind 在 dist/pagefind 生成索引与 UI
// 这里只放一个挂载点 + 样式包裹，UI 由 Pagefind 注入
const base = import.meta.env.BASE_URL;
const pagefindCss = `${base}pagefind/pagefind-ui.css`;
---
<div class="search-footnote">
  <div class="search-label">search / footnote</div>
  <div id="search"></div>
</div>

<link rel="stylesheet" href={pagefindCss} />

<style>
  /* 把 Pagefind UI 嵌进纸面脚注外观 */
  :global(#search .pagefind-ui) {
    --pagefind-ui-scale: 0.9;
    border: none !important;
    background: transparent !important;
    box-shadow: none !important;
    border-radius: 0 !important;
  }
  :global(#search .pagefind-ui__search-input) {
    background: transparent !important;
    border: none !important;
    color: rgb(var(--color-fg)) !important;
    padding: 0.55rem 0 !important;
    height: auto !important;
    font-family: JetBrains Mono, Consolas, monospace !important;
    font-size: 0.85rem !important;
  }
  :global(#search .pagefind-ui__search-input::placeholder) {
    color: rgb(var(--color-muted)) !important;
  }
  :global(#search .pagefind-ui__drawer) {
    background: rgb(var(--color-surface)) !important;
    backdrop-filter: none;
    border: 1px solid rgb(var(--color-border)) !important;
    border-radius: 0 !important;
    box-shadow: 8px 8px 0 rgb(var(--color-shadow) / 0.12) !important;
  }
  :global(#search .pagefind-ui__result-link) {
    color: rgb(var(--color-fg)) !important;
  }
  :global(#search .pagefind-ui__result-excerpt) {
    color: rgb(var(--color-muted)) !important;
  }
</style>

<script>
  // 客户端按需加载 Pagefind UI
  async function initPagefind() {
    const el = document.getElementById('search');
    if (!el) return;
    try {
      const base = import.meta.env.BASE_URL;
      const pagefindUrl = `${base}pagefind/pagefind-ui.js`;
      // @ts-ignore - pagefind-ui.js 由构建后生成
      const { PagefindUI } = await import(/* @vite-ignore */ pagefindUrl);
      new PagefindUI({
        element: '#search',
        showSubResults: true,
        translations: {
          placeholder: '搜索文章…',
          zero_results: '没有找到相关文章',
          clear_search: '清除',
        },
      });
    } catch (e) {
      // 本地 dev 模式下 /pagefind 还不存在，静默降级
      el.innerHTML =
        '<div class="py-2 text-sm text-muted">搜索索引正在准备，发布后自动接入。</div>';
    }
  }
  initPagefind();
</script>
